# ─────────────────────────────────────────────────────────────────────────────
# RAGSmith – Environment Configuration Template
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
#
# .env is in .gitignore — NEVER commit it to source control.
#
# Both Ollama and Groq are available simultaneously.
# The provider used per-query is set on the project, not here.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=change-me-use-openssl-rand-hex-32
LOG_LEVEL=INFO

# ── Database ──────────────────────────────────────────────────────────────────
DB_DRIVER=sqlite                          # "sqlite" | "postgres"
SQLITE_PATH=data/ragsmith.db

# Fill this in when DB_DRIVER=postgres
DATABASE_URL=postgresql://postgres:password@localhost:5432/RAGSmith

# ── Ollama (local) ────────────────────────────────────────────────────────────
# Always available when Ollama is running locally.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=mistral:7b

# ── Groq (cloud) ─────────────────────────────────────────────────────────────
# Available when GROQ_API_KEY is set. Get a free key at https://console.groq.com
# You can also set this key from the App Settings UI (⚙ in the sidebar).
GROQ_API_KEY=
GROQ_DEFAULT_MODEL=llama-3.1-8b-instant

# ── Embedding Model ───────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── File Storage ─────────────────────────────────────────────────────────────
STORAGE_BACKEND=local                     # "local" | "s3"
LOCAL_UPLOAD_DIR=data/uploads

# AWS S3 (only needed when STORAGE_BACKEND=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=ragsmith-uploads

# ── FAISS / Vector Indexes ────────────────────────────────────────────────────
FAISS_INDEX_DIR=data/indexes
FAISS_CHUNKS_DIR=data/chunks

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
WORKERS=1
RELOAD=false

# ── Upload Limits ─────────────────────────────────────────────────────────────
MAX_UPLOAD_MB=50

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=*
